generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  BUSINESS_OWNER
  MANAGER
  RECOVERY_AGENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BusinessPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  DISPUTED
}

enum OutstandingStatus {
  ACTIVE
  CLEARED
  DISPUTED
  WRITTEN_OFF
}

enum CampaignType {
  WHATSAPP
  CALL
  EMAIL
  SMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  PAUSED
  CANCELLED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CallStatus {
  PENDING
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
}

enum DeliveryStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum PTPStatus {
  PENDING
  KEPT
  BROKEN
  RESCHEDULED
}

// ─── Billing Enums ────────────────────────────────────────────────────────────

enum OnboardingStatus {
  PENDING
  KEYS_ADDED
  PAID
  ACTIVE
}

enum BillingPaymentType {
  ONBOARDING
  SUBSCRIPTION
}

enum BillingPaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum BillingSubscriptionStatus {
  ACTIVE
  PENDING
  HALTED
  CANCELLED
}

enum UsageSource {
  BOLNA
  AISENSY
}

enum BillingNotificationKind {
  BOLNA_LOW
  AISENSY_LOW
  MANDATE_FAILED
  DEBIT_SUCCESS
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Business {
  id             String         @id @default(uuid())
  name           String
  status         BusinessStatus @default(ACTIVE)
  plan           BusinessPlan   @default(FREE)
  // Per-business segment day ranges; null = platform defaults
  segment_rules  Json?
  // Number the AI transfers a call to when the customer asks for a human/senior.
  // Null = fall back to the platform default (BOLNA_HANDOFF_NUMBER env var).
  handoff_number String?
  // VIP-only override: { min_days, max_days, segment }. VIP customers whose
  // days overdue fall in this range are contacted (manually: VIPs are never
  // auto-contacted) with the chosen segment's script/template instead of the
  // day-range segment. Null = no override.
  vip_rule       Json?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  // ─── Billing: per-tenant third-party accounts + Razorpay linkage ──────────
  // API keys are AES-256-GCM encrypted with BILLING_ENCRYPTION_KEY. They are
  // NEVER returned by any API and never logged: only last-4 previews leave
  // the backend.
  bolna_api_key             String?
  bolna_agent_id            String?
  aisensy_api_key           String?
  low_balance_threshold_usd Float            @default(5)
  billing_email             String?
  gstin                     String?
  razorpay_customer_id      String?
  onboarding_status         OnboardingStatus @default(PENDING)
  // Admin checklist: manually toggled after a successful live test call
  test_call_passed          Boolean          @default(false)

  // Relations
  users                 User[]
  customers             Customer[]
  invoices              Invoice[]
  outstandings          Outstanding[]
  campaigns             Campaign[]
  whatsapp_logs         WhatsAppLog[]
  call_logs             CallLog[]
  ai_analyses           AIAnalysis[]
  promises_to_pay       PromiseToPay[]
  import_templates      ImportTemplate[]
  import_histories      ImportHistory[]
  pdc_cheques           PdcCheque[]
  pdc_upload_histories  PdcUploadHistory[]
  billing_payments      BillingPayment[]
  billing_subscriptions BillingSubscription[]
  billing_invoices      BillingInvoice[]
  usage_snapshots       UsageSnapshot[]
  billing_notifications BillingNotification[]
  coupons_used          Coupon[]

  @@map("businesses")
}

model User {
  id           String     @id @default(uuid())
  business_id  String
  supabase_uid String     @unique
  email        String
  role         UserRole   @default(RECOVERY_AGENT)
  status       UserStatus @default(ACTIVE)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  // Relations
  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@unique([email, business_id])
  @@index([business_id])
  @@index([supabase_uid])
  @@map("users")
}

model Customer {
  id              String   @id @default(uuid())
  business_id     String
  customer_name   String
  phone           String?
  // Fallback numbers (Excel rows can carry several) — dialed in order when the
  // primary number goes unanswered; the chain stops at the first answered call.
  alt_phones      String[] @default([])
  email           String?
  city            String?
  tags            String[] @default([])
  is_vip          Boolean  @default(false)
  // Sales agent from the latest import (Excel AGENT column, party-level)
  assigned_agent  String?
  // Per-customer segment day-range override; same shape as
  // businesses.segment_rules. Null = follow the business rules.
  custom_schedule Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  business        Business       @relation(fields: [business_id], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  outstanding     Outstanding?
  pdc_cheques     PdcCheque[]
  whatsapp_logs   WhatsAppLog[]
  call_logs       CallLog[]
  ai_analyses     AIAnalysis[]
  promises_to_pay PromiseToPay[]

  // No unique constraint on phone — several parties can share one number
  // (same proprietor, several shops). Party name is the identity.
  @@index([business_id])
  @@index([customer_name])
  @@map("customers")
}

model Invoice {
  id             String        @id @default(uuid())
  business_id    String
  customer_id    String
  invoice_number String
  invoice_date   DateTime
  amount         Float         @default(0)
  due_amount     Float
  days_overdue   Int           @default(0)
  sales_agent    String?
  status         InvoiceStatus @default(PENDING)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  // Relations
  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  // Bill numbers are only unique per party: Tally reuses payment
  // references ("UPI", "NEFT") as bill numbers across many parties
  @@unique([customer_id, invoice_number])
  @@index([business_id])
  @@index([customer_id])
  @@index([status])
  @@map("invoices")
}

model Outstanding {
  id                 String            @id @default(uuid())
  business_id        String
  customer_id        String            @unique
  total_due          Float             @default(0)
  aging_bucket       String            @default("0-60")
  segment            String            @default("Soft Reminder")
  status             OutstandingStatus @default(ACTIVE)
  pdc_cooldown_until DateTime?
  total_pdc_cleared  Float             @default(0)
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  // Relations
  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@index([segment])
  @@index([status])
  @@map("outstandings")
}

model Campaign {
  id           String         @id @default(uuid())
  business_id  String
  name         String
  type         CampaignType
  status       CampaignStatus @default(DRAFT)
  scheduled_at DateTime?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  // Relations
  business      Business      @relation(fields: [business_id], references: [id], onDelete: Cascade)
  whatsapp_logs WhatsAppLog[]
  call_logs     CallLog[]

  @@index([business_id])
  @@index([status])
  @@map("campaigns")
}

model WhatsAppLog {
  id              String         @id @default(uuid())
  business_id     String
  customer_id     String
  campaign_id     String?
  message         String
  reply           String?
  delivery_status DeliveryStatus @default(SENT)
  created_at      DateTime       @default(now())

  // Relations
  business Business  @relation(fields: [business_id], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaign_id], references: [id], onDelete: SetNull)

  @@index([business_id])
  @@index([customer_id])
  @@map("whatsapp_logs")
}

model CallLog {
  id               String     @id @default(uuid())
  business_id      String
  customer_id      String
  campaign_id      String?
  transcript       String?
  recording_url    String?
  call_status      CallStatus @default(PENDING)
  duration_seconds Int?
  created_at       DateTime   @default(now())

  // Bolna call tracking + post-call extraction (mirrors DemoRun fields)
  retell_call_id           String?          @unique
  call_summary             String?
  disposition              CallDisposition?
  call_sentiment           CallSentiment?
  promise_date             DateTime?
  key_objection            String?
  language_used            CallLanguage?
  is_sensitive             Boolean          @default(false)
  sensitive_cooldown_until DateTime?
  // Customer asked for the statement on WhatsApp during the call
  whatsapp_requested       Boolean          @default(false)
  whatsapp_fulfilled       Boolean          @default(false)
  // Auto-scheduled callback re-dial time (customer said "baadme"/"kal"/etc.)
  next_call_at             DateTime?
  // The number actually dialed (primary or an alt_phones fallback) — lets the
  // webhook pick the NEXT number when this one goes unanswered.
  dialed_phone             String?
  // Per-call Bolna cost in USD, backfilled by the usage poller from
  // /v2/agent/:id/executions. Null until the poller sees the execution.
  bolna_cost_usd           Float?

  // Relations
  business Business  @relation(fields: [business_id], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaign_id], references: [id], onDelete: SetNull)

  @@index([business_id])
  @@index([customer_id])
  @@map("call_logs")
}

model AIAnalysis {
  id          String   @id @default(uuid())
  business_id String
  customer_id String
  sentiment   String?
  intent      String?
  risk_score  Float?
  summary     String?
  created_at  DateTime @default(now())

  // Relations
  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@index([customer_id])
  @@map("ai_analyses")
}

model PromiseToPay {
  id              String    @id @default(uuid())
  business_id     String
  customer_id     String
  promised_amount Float
  promised_date   DateTime
  status          PTPStatus @default(PENDING)
  notes           String?
  created_at      DateTime  @default(now())

  // Relations
  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@index([customer_id])
  @@map("promises_to_pay")
}

model ImportTemplate {
  id          String   @id @default(uuid())
  business_id String
  name        String
  mappings    Json
  created_at  DateTime @default(now())

  // Relations
  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@unique([name, business_id])
  @@index([business_id])
  @@map("import_templates")
}

model ImportHistory {
  id               String       @id @default(uuid())
  business_id      String
  file_name        String
  file_url         String
  status           ImportStatus @default(PENDING)
  records_total    Int          @default(0)
  records_imported Int          @default(0)
  records_failed   Int          @default(0)
  error_log        Json         @default("[]")
  // Full result stats (customers/invoices created etc.) written when the
  // background import finishes: imports run detached from the HTTP request
  // (long Tally files outlive proxy timeouts) and the dashboard polls this.
  result_summary   Json?
  created_at       DateTime     @default(now())

  // Relations
  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@map("import_histories")
}

// Created directly in Supabase Table Editor (outside Prisma). Modeled here so
// `prisma db push` never tries to drop it.
model ColumnConfig {
  id              BigInt    @id @default(autoincrement())
  column_name     String    @unique
  display_order   Int
  is_visible      Boolean?
  data_type       String?
  validation_rule String?
  created_at      DateTime? @db.Timestamptz

  @@map("column_config")
}

// ─── Demo Models ──────────────────────────────────────────────────────────────

enum PdcStatus {
  PENDING
  CLEARED
  BOUNCED
}

enum DemoLeadStatus {
  SIGNED_UP
  EXHAUSTED
}

enum DemoRunStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

enum DemoType {
  WHATSAPP
  VOICE_CALL
}

enum CallDisposition {
  INTERESTED
  NOT_INTERESTED
  CALLBACK
  PTP
  DISPUTE
  NO_ANSWER
  UNKNOWN
}

enum CallSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  HOSTILE
  UNKNOWN
}

enum CallLanguage {
  HINDI
  ENGLISH
  MIXED
  UNKNOWN
}

// Emails permitted to use import/calling/WhatsApp while the product is in
// closed testing. Managed directly in Supabase Table Editor — add a row to
// grant access.
model AllowedEmail {
  email      String   @id
  note       String?
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("allowed_emails")
}

model DemoLead {
  id                String         @id @default(uuid())
  name              String
  phone             String         @unique
  email             String
  business_name     String
  business_type     String
  city              String         @default("")
  group_name        String
  reference_by      String
  parties_range     String
  outstanding_range String
  status            DemoLeadStatus @default(SIGNED_UP)
  whatsapp_allowed  Int            @default(4)
  whatsapp_used     Int            @default(0)
  calls_allowed     Int            @default(4)
  calls_used        Int            @default(0)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  runs DemoRun[]

  @@map("demo_leads")
}

model DemoRun {
  id                 String        @id @default(uuid())
  demo_lead_id       String
  demo_type          DemoType
  party_name         String
  bill_amount        Float
  status             DemoRunStatus @default(PENDING)
  retell_call_id     String?       @unique
  call_recording_url String?
  created_at         DateTime      @default(now())

  // Structured extraction fields (populated after call_analyzed webhook, no raw transcript stored)
  call_summary             String?
  disposition              CallDisposition?
  call_sentiment           CallSentiment?
  promise_date             DateTime?
  key_objection            String?
  follow_up_required       Boolean          @default(false)
  follow_up_notes          String?
  language_used            CallLanguage?
  talk_ratio               Float?
  extracted_at             DateTime?
  // Sensitive situation — death/medical emergency triggers 18-day calling cooldown
  is_sensitive             Boolean          @default(false)
  sensitive_cooldown_until DateTime?

  // Relations
  demo_lead DemoLead @relation(fields: [demo_lead_id], references: [id], onDelete: Cascade)

  @@index([demo_lead_id])
  @@index([disposition])
  @@map("demo_runs")
}

// ─── PDC Cheque Models ────────────────────────────────────────────────────────

model PdcUploadHistory {
  id              String   @id @default(uuid())
  business_id     String
  file_name       String
  records_total   Int      @default(0)
  records_matched Int      @default(0)
  records_cleared Int      @default(0)
  created_at      DateTime @default(now())

  business Business    @relation(fields: [business_id], references: [id], onDelete: Cascade)
  cheques  PdcCheque[]

  @@index([business_id])
  @@map("pdc_upload_histories")
}

model PdcCheque {
  id              String    @id @default(uuid())
  business_id     String
  customer_id     String?
  upload_batch_id String
  party_name      String
  cheque_no       String
  cheque_date     DateTime
  amount          Float
  status          PdcStatus @default(PENDING)
  cleared_date    DateTime?
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  business     Business         @relation(fields: [business_id], references: [id], onDelete: Cascade)
  customer     Customer?        @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  upload_batch PdcUploadHistory @relation(fields: [upload_batch_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@index([customer_id])
  @@index([status])
  @@map("pdc_cheques")
}

// ─── Billing Models ───────────────────────────────────────────────────────────
// PraecisAI charges tenants exactly two things via Razorpay: a one-time
// onboarding fee (₹50,000 ex-GST, includes the first month) and a ₹5,000/month
// ex-GST subscription auto-debited on the 1st. All stored amounts are PAISE
// integers, ex-GST unless the field name says otherwise. Bolna/AiSensy money
// never flows through Praecis: tenants pay those platforms directly.

model Coupon {
  id                String    @id @default(uuid())
  code              String    @unique
  percent           Int // 5 | 10 | 15 | 20 (validated in service)
  max_uses          Int       @default(1)
  used_count        Int       @default(0)
  expires_at        DateTime?
  active            Boolean   @default(true)
  used_by_tenant_id String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  used_by  Business?        @relation(fields: [used_by_tenant_id], references: [id], onDelete: SetNull)
  payments BillingPayment[]

  @@index([code])
  @@map("coupons")
}

model BillingPayment {
  id                       String               @id @default(uuid())
  business_id              String
  type                     BillingPaymentType
  razorpay_order_id        String?
  razorpay_payment_id      String?              @unique
  razorpay_subscription_id String?
  // All amounts in PAISE. base/discount/setup/subscription are ex-GST.
  base_amount              Int
  discount_amount          Int                  @default(0)
  setup_component          Int                  @default(0)
  subscription_component   Int                  @default(0)
  gst_amount               Int
  total_amount             Int
  status                   BillingPaymentStatus @default(CREATED)
  paid_at                  DateTime?
  coupon_id                String?
  created_at               DateTime             @default(now())
  updated_at               DateTime             @updatedAt

  business Business        @relation(fields: [business_id], references: [id], onDelete: Cascade)
  coupon   Coupon?         @relation(fields: [coupon_id], references: [id], onDelete: SetNull)
  invoice  BillingInvoice?

  @@index([business_id])
  @@index([razorpay_subscription_id])
  @@map("billing_payments")
}

model BillingSubscription {
  id                       String                    @id @default(uuid())
  business_id              String                    @unique
  razorpay_subscription_id String?                   @unique
  plan_amount              Int                       @default(500000) // ₹5,000 ex-GST in paise
  status                   BillingSubscriptionStatus @default(PENDING)
  next_debit_date          DateTime?
  mandate_type             String? // upi | card | emandate (as reported by Razorpay)
  created_at               DateTime                  @default(now())
  updated_at               DateTime                  @updatedAt

  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("billing_subscriptions")
}

model BillingInvoice {
  id             String   @id @default(uuid())
  business_id    String
  payment_id     String?  @unique
  invoice_number String   @unique // PRAE/25-26/0001 (financial-year prefixed)
  line_items     Json // [{ description, amount }] amounts in paise, ex-GST
  taxable_value  Int // paise
  gst            Int // paise
  total          Int // paise
  pdf_url        String? // storage path inside the billing-invoices bucket
  created_at     DateTime @default(now())

  business Business        @relation(fields: [business_id], references: [id], onDelete: Cascade)
  payment  BillingPayment? @relation(fields: [payment_id], references: [id], onDelete: SetNull)

  @@index([business_id])
  @@map("billing_invoices")
}

model UsageSnapshot {
  id          String      @id @default(uuid())
  business_id String
  source      UsageSource
  balance     Float // USD for Bolna
  captured_at DateTime    @default(now())

  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id, source, captured_at])
  @@map("usage_snapshots")
}

model BillingNotification {
  id          String                  @id @default(uuid())
  business_id String
  kind        BillingNotificationKind
  message     String
  read_at     DateTime?
  // Set when the condition self-heals (e.g. balance recovered above the
  // threshold): an open (resolved_at = null) low-balance notification also
  // suppresses duplicate alerts on every poll.
  resolved_at DateTime?
  created_at  DateTime                @default(now())

  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id, kind])
  @@index([read_at])
  @@map("billing_notifications")
}

// Razorpay webhook idempotency: one row per processed event id. A replayed or
// duplicated delivery finds the row and is acknowledged without re-processing.
model RazorpayEvent {
  event_id     String   @id
  event_type   String
  processed_at DateTime @default(now())

  @@map("razorpay_events")
}
